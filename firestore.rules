rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isFamilyId(familyId) {
      return familyId.matches('^[A-F0-9]{32}$');
    }

    function familyPath(familyId) {
      return /databases/$(database)/documents/families/$(familyId);
    }

    function memberPath(familyId, uid) {
      return /databases/$(database)/documents/families/$(familyId)/members/$(uid);
    }

    function isFamilyMember(familyId) {
      return isSignedIn() &&
        isFamilyId(familyId) &&
        exists(memberPath(familyId, request.auth.uid));
    }

    function hasOnlyFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    match /families/{familyId} {
      allow get: if isSignedIn() && isFamilyId(familyId);
      allow list: if false;

      allow create: if isSignedIn() &&
        isFamilyId(familyId) &&
        hasOnlyFields(['seededAt', 'schemaVersion']) &&
        request.resource.data.seededAt is number &&
        request.resource.data.schemaVersion == 1;

      allow update: if isFamilyMember(familyId) &&
        hasOnlyFields(['seededAt', 'schemaVersion']) &&
        request.resource.data.seededAt is number &&
        request.resource.data.schemaVersion == 1;

      allow delete: if false;

      match /members/{uid} {
        allow get, list: if isFamilyMember(familyId);

        allow create: if isSignedIn() &&
          isFamilyId(familyId) &&
          request.auth.uid == uid &&
          (
            exists(familyPath(familyId)) ||
            getAfter(familyPath(familyId)).data.schemaVersion == 1
          ) &&
          hasOnlyFields(['createdAt', 'deviceName']) &&
          request.resource.data.createdAt is number &&
          request.resource.data.deviceName is string;

        allow update: if isFamilyMember(familyId) &&
          request.auth.uid == uid &&
          hasOnlyFields(['createdAt', 'deviceName']) &&
          request.resource.data.createdAt is number &&
          request.resource.data.deviceName is string;

        allow delete: if false;
      }

      match /categories/{categoryId} {
        allow read, write: if isFamilyMember(familyId);
      }

      match /family_members/{memberId} {
        allow read, write: if isFamilyMember(familyId);
      }

      match /packing_items/{itemId} {
        allow read, write: if isFamilyMember(familyId);
      }

      match /morning_items/{itemId} {
        allow read, write: if isFamilyMember(familyId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
